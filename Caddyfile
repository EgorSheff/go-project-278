:80

# Статика из /app/public
root * /app/public

# Отдаём /assets/* как есть
handle /assets/* {
    file_server
}

# Отдаём корень как index.html
handle / {
    file_server
}

# Всё остальное — в приложение на 8080
reverse_proxy localhost:8080 {
    header_up X-Forwarded-For {remote_host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
}
